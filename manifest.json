{
  "manifest_version": 3,
  "name": "Multi-LLM Chat Extractor",
  "version": "2.1",
  "description": "Extract chats from ChatGPT, Gemini, Claude, and Grok in real-time",

  "permissions": ["activeTab"],

  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "https://claude.ai/*",
    "https://www.claude.ai/*",
    "https://x.ai/*",
    "https://grok.x.ai/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*",
        "https://www.claude.ai/*",
        "https://x.ai/*",
        "https://grok.x.ai/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}