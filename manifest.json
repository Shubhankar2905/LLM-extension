{
  "manifest_version": 3,
  "name": "ChatGPT Extractor",
  "version": "1.2",
  "description": "Extract ChatGPT messages with full formatting + code support",

  "permissions": ["activeTab"],

  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}